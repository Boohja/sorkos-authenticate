{
  "openapi": "3.1.0",
  "info": {
    "title": "Sorkos Login API",
    "version": "1.0.0",
    "description": "Endpoint contract for client projects integrating with Sorkos Login. This system is for registered Sorkos projects only and is not intended for public self-service use.\n\nImplementation status: /authorize validation and the provider-selection screen exist. Provider redirects, provider callbacks, authorization-code issuing, /token, and /logout are planned but not implemented yet."
  },
  "servers": [
    {
      "url": "https://auth.test",
      "description": "Current local Sorkos Login host"
    }
  ],
  "tags": [
    {
      "name": "Authorization",
      "description": "Browser-facing authorization-code flow endpoints."
    },
    {
      "name": "Token",
      "description": "Server-side code exchange endpoints."
    },
    {
      "name": "Session",
      "description": "Central Sorkos Login session endpoints."
    }
  ],
  "paths": {
    "/authorize": {
      "get": {
        "tags": ["Authorization"],
        "summary": "Start authorization-code flow",
        "description": "Starts the authorization-code flow for a registered client project.",
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "description": "Public client identifier stored in auth_clients.client_id.",
            "schema": {
              "type": "string",
              "example": "example-id"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "description": "Callback URL. It must exactly match a row in auth_client_redirect_uris.",
            "schema": {
              "type": "string",
              "format": "uri",
              "example": "https://client.example/auth/callback"
            }
          },
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "description": "Currently only code.",
            "schema": {
              "type": "string",
              "enum": ["code"],
              "example": "code"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "description": "Random value generated by the client project and validated by the client after redirect.",
            "schema": {
              "type": "string",
              "example": "example-state"
            }
          },
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "description": "Requested profile fields. Version 1 expects basic profile/email scopes only.",
            "schema": {
              "type": "string",
              "example": "profile email"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "Preferred UI language, constrained by the client settings.",
            "schema": {
              "type": "string",
              "enum": ["en", "de"],
              "example": "en"
            }
          },
          {
            "name": "prompt",
            "in": "query",
            "required": false,
            "description": "Reserved for later consent/account-selection behavior.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Valid request and no central login session, showing the provider-selection page.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid client, redirect URI, response type, or missing state.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/google/start": {
      "get": {
        "tags": ["Authorization"],
        "summary": "Start Google provider login",
        "description": "Redirects the user to Google after validating the pending authorization request. Planned, not implemented yet.",
        "responses": {
          "302": {
            "description": "Redirect to the external OAuth provider."
          },
          "400": {
            "description": "Error page if no valid pending authorization request exists.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/discord/start": {
      "get": {
        "tags": ["Authorization"],
        "summary": "Start Discord provider login",
        "description": "Redirects the user to Discord after validating the pending authorization request. Planned, not implemented yet.",
        "responses": {
          "302": {
            "description": "Redirect to the external OAuth provider."
          },
          "400": {
            "description": "Error page if no valid pending authorization request exists.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/google/callback": {
      "get": {
        "tags": ["Authorization"],
        "summary": "Receive Google callback",
        "description": "Receives the Google callback, creates or updates the Sorkos Login user, creates the central auth session, then continues the original authorization request. Planned, not implemented yet.",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "description": "Provider authorization code.",
            "schema": {
              "type": "string",
              "example": "example-provider-code"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "description": "Provider state generated by Sorkos Login.",
            "schema": {
              "type": "string",
              "example": "example-provider-state"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect back to the original client redirect_uri with code and the original client state."
          },
          "400": {
            "description": "Error page if provider state validation or provider login fails.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/discord/callback": {
      "get": {
        "tags": ["Authorization"],
        "summary": "Receive Discord callback",
        "description": "Receives the Discord callback, creates or updates the Sorkos Login user, creates the central auth session, then continues the original authorization request. Planned, not implemented yet.",
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "description": "Provider authorization code.",
            "schema": {
              "type": "string",
              "example": "example-provider-code"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "description": "Provider state generated by Sorkos Login.",
            "schema": {
              "type": "string",
              "example": "example-provider-state"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect back to the original client redirect_uri with code and the original client state."
          },
          "400": {
            "description": "Error page if provider state validation or provider login fails.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/token": {
      "post": {
        "tags": ["Token"],
        "summary": "Exchange authorization code",
        "description": "Exchanges a short-lived authorization code for normalized user information. This request is made server-side by the client project. Planned, not implemented yet.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Normalized Sorkos Login user information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request, code, grant type, client credentials, or redirect URI.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/logout": {
      "get": {
        "tags": ["Session"],
        "summary": "Destroy central session",
        "description": "Destroys the central Sorkos Login session. Client projects still handle their own local logout separately. Planned, not implemented yet.",
        "responses": {
          "200": {
            "description": "Logout confirmation, or redirect if a return target is added later.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TokenRequest": {
        "type": "object",
        "required": ["grant_type", "code", "client_id", "client_secret", "redirect_uri"],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": ["authorization_code"]
          },
          "code": {
            "type": "string",
            "description": "The code returned to the client callback.",
            "example": "example-code"
          },
          "client_id": {
            "type": "string",
            "description": "The client identifier.",
            "example": "example-id"
          },
          "client_secret": {
            "type": "string",
            "description": "The client secret for confidential server-side clients.",
            "example": "example-secret"
          },
          "redirect_uri": {
            "type": "string",
            "format": "uri",
            "description": "The same redirect URI used in /authorize.",
            "example": "https://client.example/auth/callback"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "required": ["user"],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "User": {
        "type": "object",
        "required": ["id", "email_verified"],
        "properties": {
          "id": {
            "type": "string",
            "example": "usr_example"
          },
          "email": {
            "type": ["string", "null"],
            "format": "email",
            "example": "user@example.com"
          },
          "email_verified": {
            "type": "boolean",
            "example": true
          },
          "display_name": {
            "type": ["string", "null"],
            "example": "User Name"
          },
          "avatar_url": {
            "type": ["string", "null"],
            "format": "uri",
            "example": null
          },
          "preferred_language": {
            "type": ["string", "null"],
            "enum": ["en", "de", null],
            "example": "de"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string",
            "example": "invalid_request"
          },
          "error_description": {
            "type": "string",
            "example": "The authorization code is invalid or expired."
          }
        }
      }
    }
  }
}
